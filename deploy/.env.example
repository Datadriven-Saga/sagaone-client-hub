# ==========================================
# VARIÁVEIS DE AMBIENTE - DEPLOY PRODUCTION
# Sistema de CRM e Prospecção com Agentes IA
# ==========================================

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# Database URL for migrations (usado pelo script de deploy)
DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# Application Settings
NODE_ENV=production
VITE_APP_NAME="Sistema CRM e Prospecção"
VITE_APP_VERSION="1.0.0"

# ==========================================
# INSTRUÇÕES DE CONFIGURAÇÃO
# ==========================================

# 1. Copie este arquivo para .env:
#    cp .env.example .env

# 2. Substitua os valores com suas credenciais do Supabase:
#    - Acesse https://supabase.com/dashboard
#    - Selecione seu projeto
#    - Vá em Settings > API
#    - Copie as credenciais necessárias

# 3. Para DATABASE_URL:
#    - Vá em Settings > Database
#    - Copie a Connection String
#    - Substitua [YOUR-PASSWORD] pela senha do banco

# ==========================================
# SECRETS DO SUPABASE FUNCTIONS
# ==========================================

# Os seguintes secrets devem ser configurados no Supabase:
# (Settings > Edge Functions > Secrets)

# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_DB_URL=postgresql://postgres:password@localhost:5432/postgres

# ==========================================
# CONFIGURAÇÕES OPCIONAIS
# ==========================================

# Webhook URLs para integrações externas
# WEBHOOK_URL_BASE=https://your-webhook-service.com

# Analytics e Monitoramento
# SENTRY_DSN=https://your-sentry-dsn
# GOOGLE_ANALYTICS_ID=GA-XXXXXX

# Configurações de Email (se usar serviço externo)
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_USER=your-user
# SMTP_PASS=your-password

# ==========================================
# NOTAS IMPORTANTES
# ==========================================

# ⚠️  NUNCA commite este arquivo com dados reais
# ⚠️  Use o GitHub Secrets ou similar para CI/CD
# ⚠️  Rotacione as chaves regularmente
# ⚠️  Use conexões SSL em produção

# ✅ Este arquivo deve estar no .gitignore
# ✅ Mantenha backups seguros das configurações
# ✅ Documente mudanças de configuração